
FROM node:18-alpine AS builder

WORKDIR /app

COPY package*.json ./

RUN npm install


COPY . .

FROM node:18-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install --omit=dev

COPY --from=builder /app/node_modules ./node_modules

COPY . .

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

RUN chown -R appuser:appgroup /app


USER appuser


EXPOSE 3000


CMD ["node", "app.js"]